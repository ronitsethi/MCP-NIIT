# =============================================================================
# NIIT Learning Advisor MCP Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for real integrations.
# All values below are optional while running with mocks.

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Mock delay in milliseconds (simulates backend latency)
MOCK_DELAY_MS=200

# --- Future integration endpoints ---
# CRM_API_BASE_URL=https://crm.example.com/api
# CRM_API_KEY=
# LMS_API_BASE_URL=https://lms.example.com/api
# LMS_API_KEY=
# SURVEY_SERVICE_URL=https://surveys.example.com/api
# TICKETING_SERVICE_URL=https://tickets.example.com/api
